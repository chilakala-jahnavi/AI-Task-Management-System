# ============================================
# TASK MANAGEMENT SYSTEM - ENVIRONMENT VARIABLES
# ============================================

# ============ SECURITY ============
# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-to-generate

# Token expiration times (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440          # 24 hours
REFRESH_TOKEN_EXPIRE_MINUTES=10080        # 7 days

# ============ DATABASE ============
# MySQL Database Configuration
# Format: mysql+pymysql://username:password@host:port/database_name
# Updated with your credentials
DATABASE_URL=mysql+pymysql://root:Jahnavi%402004@localhost:3306/task_management

# Connection Pool Settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=False                       # Set to True for SQL query logging

# ============ AI / MACHINE LEARNING ============
# Sentence Transformer Model for embeddings
# Options: all-MiniLM-L6-v2, all-mpnet-base-v2, multi-qa-mpnet-base-dot-v1
EMBEDDING_MODEL=all-MiniLM-L6-v2

# FAISS Index Configuration
FAISS_INDEX_PATH=faiss_index.bin
METADATA_PATH=metadata.pkl

# Text Chunking Parameters
CHUNK_SIZE=500                            # Words per chunk
CHUNK_OVERLAP=100                         # Overlap between chunks
TOP_K_RESULTS=5                           # Default number of search results

# ============ FILE UPLOAD ============
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760                    # 10MB in bytes (10 * 1024 * 1024)
ALLOWED_EXTENSIONS=.txt,.pdf,.docx,.md    # Comma-separated list

# ============ SERVER ============
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True                            # Set to False in production
API_PREFIX=/api/v1

# ============ CORS ============
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001

# ============ LOGGING ============
LOG_LEVEL=INFO                            # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============ RATE LIMITING ============
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100                   # Maximum requests per period
RATE_LIMIT_PERIOD=60                      # Period in seconds

# ============ REDIS (Optional - for caching) ============
REDIS_ENABLED=False
REDIS_URL=redis://localhost:6379/0

# ============ ENVIRONMENT ============
# Options: development, staging, production
ENVIRONMENT=development

# ============ EMAIL (Optional) ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@taskmanagement.com

# ============ FEATURE FLAGS ============
ENABLE_DOCUMENT_UPLOAD=True
ENABLE_TASK_ASSIGNMENT=True
ENABLE_SEARCH_LOGGING=True
ENABLE_ANALYTICS=True