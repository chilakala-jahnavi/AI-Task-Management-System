# ============================================
# REACT APP ENVIRONMENT VARIABLES (EXAMPLE)
# ============================================

# ============================================
# API Configuration
# ============================================
REACT_APP_API_URL=http://localhost:8000/api/v1

# ============================================
# Environment
# ============================================
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0

# ============================================
# Feature Flags
# ============================================
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_DOCUMENT_UPLOAD=true
REACT_APP_ENABLE_SEMANTIC_SEARCH=true
REACT_APP_ENABLE_ACTIVITY_LOG=true

# ============================================
# File Upload Limits
# ============================================
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_ALLOWED_FILE_TYPES=.txt,.pdf

# ============================================
# Pagination Defaults
# ============================================
REACT_APP_DEFAULT_PAGE_SIZE=10
REACT_APP_MAX_PAGE_SIZE=100

# ============================================
# Search Configuration
# ============================================
REACT_APP_DEFAULT_SEARCH_RESULTS=5
REACT_APP_MAX_SEARCH_RESULTS=20

# ============================================
# Toast Notification Duration
# ============================================
REACT_APP_TOAST_DURATION=5000

# ============================================
# Session Configuration
# ============================================
REACT_APP_SESSION_TIMEOUT=3600

# ============================================
# Theme Configuration
# ============================================
REACT_APP_DEFAULT_THEME=light

# ============================================
# Debug Mode
# ============================================
REACT_APP_DEBUG=false

# ============================================
# Development Specific
# ============================================
REACT_APP_BYPASS_AUTH=false
REACT_APP_ENABLE_API_LOGGING=false